SECRET_KEY=change-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false

# Comma-separated list of hosts the drug-lookup parser is allowed to fetch.
# Leave empty to disable the lookup feature entirely.
DRUG_LOOKUP_ALLOWED_HOSTS=

# Local dev uses SQLite. Prod compose derives DATABASE_URL from the POSTGRES_* values below.
DATABASE_URL=

# Cache and rate-limiting backend. Local dev falls back to an in-process LocMemCache
# when empty. Prod compose defaults to redis://redis:6379/0.
REDIS_URL=

# Celery broker/result backend for the background worker and beat scheduler.
# Defaults to REDIS_URL, then to redis://localhost:6379/0.
CELERY_BROKER_URL=

# VAPID keys for web-push expiry notifications. Generate with:
#   uv run vapid --gen
# Leave empty to disable push notifications.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=
VITE_VAPID_PUBLIC_KEY=

POSTGRES_DB=firstaid
POSTGRES_USER=firstaid
# Required by prod compose — set a strong password before deploying.
POSTGRES_PASSWORD=change-me-strong-password

DJANGO_PORT=8000
VITE_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api
HTTP_PORT=80
